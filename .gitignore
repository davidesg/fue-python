# Build artefacts
*.o
*.pyc
__pycache__/
*.egg-info/
dist/
build/

# cffi in-tree intermediate build (root-level fue/ directory created by ffi.compile)
/fue/

# Compiled extension (built, not committed; reproduced by pip install -e .)
src/fue/_fue_engine*.so

# Virtual environment
.venv/

# Stray .o directories from gcc run in project root
/home/

# Generated outputs from examples/
examples/*.out
examples/*.png

# Generated outputs in tests/ (fuf runs, HTML reports, PNG charts, LaTeX artefacts)
# NB: reference *.out files (RIPC.1.out etc.) ARE tracked — only ignore generated ones
tests/**/forecast_*
tests/**/fuf_*
tests/**/*_forecast.png
tests/**/*.html
tests/**/*.aux
tests/**/*.log
tests/**/*.pdf

# Artefactos de fue ejecutado con flags como nombre de archivo
/--*.out
/--*.pre
/--*.tex
/--*_res.tex
/-v.*
